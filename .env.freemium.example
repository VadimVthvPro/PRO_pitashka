# ================================================================
# Freemium stack — env-шаблон. Скопируй в .env.freemium и заполни.
#   cp .env.freemium.example .env.freemium
# ================================================================

# --- Telegram bot ---
# ВАЖНО: для параллельной версии создай в BotFather отдельного бота
# (например @PROpitashkaStars_bot). Два polling-инстанса одного и того
# же бота несовместимы (TelegramConflictError). Для вывода Stars владельцем
# бота должен быть @vadimvthv (создавай бота с этого аккаунта).
TOKEN=
TELEGRAM_TOKEN=
# Username бота (без @) — используется фронтом для кнопки "Открыть бота"
# в форме логина/OTP. ДОЛЖЕН совпадать с владельцем TOKEN.
NEXT_PUBLIC_BOT_USERNAME=

# --- JWT ---
# Сгенерируй новый, не переиспользуй прод-ключ:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_GENERATE_NEW

# --- Gemini ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Database ---
DB_NAME=propitashka
DB_USER=propitashka
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_HOST=postgres
DB_PORT=5432

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# --- Runtime ---
ENVIRONMENT=staging
CACHE_ENABLED=true

# --- Admin ---
ADMIN_DB_USER=propitashka
ADMIN_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Public URL / ports ---
# Укажи реальный адрес фронта freemium-версии (используется в CORS, ссылках
# на paywall и Telegram-сообщениях).
FRONTEND_URL=http://82.38.66.177:3201
FRONTEND_PUBLIC_PORT=3201
BACKEND_LOCAL_PORT=8102

# --- Google OAuth (опционально) ---
GOOGLE_CLIENT_ID=

# --- Freemium-специфичные ---
# Telegram-аккаунт владельца, которому уходят Stars (для отображения в UI
# и админ-логах). Не влияет на реальный вывод — Stars лежат на балансе бота.
STARS_OWNER_USERNAME=vadimvthv

# --- Cookie isolation ---
# Прод (:3200) и freemium (:3201) живут на одном хосте. HTTP cookies не
# учитывают порт (RFC 6265), поэтому куки авторизации двух стеков путались
# и ломали друг друга (JWT подписаны разными ключами → 401 навечно).
# Префикс делает имена уникальными: `fm_access_token`, `fm_refresh_token`.
AUTH_COOKIE_PREFIX=fm_
NEXT_PUBLIC_AUTH_COOKIE_PREFIX=fm_

# --- Brand (dual-brand support) ---
# Один и тот же код обслуживает два бренда: "propitashka" (для конкурса)
# и "profit" (публичный бренд). Значения должны совпадать.
#
# BRAND (backend) меняется на лету — рестарт контейнера ~5 секунд.
# NEXT_PUBLIC_BRAND (frontend) требует пересборки образа — ~2-3 минуты.
#
# Переключение: ./scripts/switch-brand.sh profit | propitashka
# Подробности: BRAND_ARCHITECTURE.md
BRAND=profit
NEXT_PUBLIC_BRAND=profit
